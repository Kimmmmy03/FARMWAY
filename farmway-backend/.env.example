# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── PostgreSQL ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=farmway
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# ─── AWS S3 ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=farmway-media

# ─── Payment Gateway (Placeholder) ───────────────────────
PAYMENT_GATEWAY=ipay88
IPAY88_MERCHANT_CODE=your_merchant_code
IPAY88_MERCHANT_KEY=your_merchant_key
PAYMENT_CALLBACK_URL=https://api.farmway.my/api/payments/callback

# ─── Weather API ──────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweather_api_key
WEATHER_CACHE_TTL_MINUTES=30

# ─── Platform Config ──────────────────────────────────────
DEFAULT_COMMISSION_RATE=8
MIN_COMMISSION_RATE=5
MAX_COMMISSION_RATE=10
CORS_ORIGIN=http://localhost:19006

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=debug
