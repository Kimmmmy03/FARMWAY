{
  "name": "farmway-backend",
  "version": "1.0.0",
  "description": "Farmway AgriTech Marketplace – REST API Server",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:setup": "node src/config/setup-db.js",
    "db:reset": "node -e \"const fs=require('fs'),p=require('path').resolve(__dirname,'data/farmway.sqlite');fs.existsSync(p)&&fs.unlinkSync(p);console.log('DB deleted')\" && node src/config/setup-db.js",
    "lint": "eslint src/"
  },
  "dependencies": {
    "aws-sdk": "^2.1550.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "i18next": "^23.10.1",
    "i18next-http-middleware": "^3.6.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "pg": "^8.11.3",
    "sequelize": "^6.37.1",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
